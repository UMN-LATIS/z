{
  "name": "z",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.yml"],
  "service": "web",
  "workspaceFolder": "/app",

  "initializeCommand": {
    "create .env": "if [ ! -f .env ]; then cp .env.example .env; fi"
  },

  // Features to add to the dev container. More info: https://containers.dev/features.
  // Ruby, Node, MySQL client, and Git are installed directly in the Dockerfile.
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
  ],

  "forwardPorts": [3000, 3306],

  "portsAttributes": {
    "3000": {
      "label": "Rails Server",
      "onAutoForward": "notify"
    },
    "3306": {
      "label": "MySQL",
      "onAutoForward": "ignore"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "aliariff.vscode-erb-beautify",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "IgorSbitnev.error-gutters",
        "ms-azuretools.vscode-docker",
        "pavlitsky.yard",
        "redhat.vscode-yaml",
        "Shopify.ruby-extensions-pack",
        "testdouble.vscode-standard-ruby",
        "vortizhe.simple-ruby-erb",
        "tombonnike.vscode-status-bar-format-toggle",
        "eamodio.gitlens",
        "christian-kohler.path-intellisense",
        "YoavBls.pretty-ts-errors",
        "Vue.volar",
        "MaxvanderSchee.web-accessibility",
        "KoichiSasada.vscode-rdbg",
        "github.vscode-github-actions"
      ]
    }
  },

  "postCreateCommand": {
    "Setup Rails": "bin/setup --skip-server"
  }
}
