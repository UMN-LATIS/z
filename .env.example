APP_URL=http://localhost:3000
RAILS_ENV=development
RAILS_SECRET=your_secret_key_base

# Server-side display timezone (ERB views, CSV exports). Does NOT affect
# database storage — data is always stored as UTC. Any Rails-valid zone
# name works, e.g. "Eastern Time (US & Canada)", "America/Los_Angeles".
APP_TIME_ZONE="Central Time (US & Canada)"

# DB
DB_HOST=db
DB_PORT=3306
DB_DATABASE=z
DB_USERNAME=root
DB_PASSWORD=
DB_ENABLE_CLEARTEXT_PLUGIN=false
DB_SSL_CA_FILE=

# LDAP
LDAP_HOST=ldap.umn.edu
LDAP_PORT=636
LDAP_BASE="o=University of Minnesota,c=US"
LDAP_USERNAME=
LDAP_PASSWORD=

# Mock LDAP in development/test
USER_LOOKUP_SKELETON=1

DISALLOW_ALL_WEB_CRAWLERS=true

# OMNIAUTH_PROVIDER="saml"
OMNIAUTH_PROVIDER="developer"

# Shibboleth
SHIB_METADATA_URL="https://login.umn.edu/metadata.xml"
SHIB_DID="https://www.umn.edu/shibboleth/attributes/umnDID"
SHIB_IS_GUEST="https://www.umn.edu/shibboleth/attributes/isGuest"
SHIB_ENTITY_ID="https://claoit.umn.edu/shibboleth/default"
SHIB_ASSERTION_CONSUMER_URL="${APP_URL}/auth/saml/callback"
SHIB_IDP_SSO="https://login.umn.edu/idp/profile/SAML2/Redirect/SSO"
SHIB_IDP_SLO="https://login.umn.edu/idp/profile/Logout"
SHIB_X509_CERT=
SHIB_PRIVATE_KEY=

SENTRY_DSN=
