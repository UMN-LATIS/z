<header class="page-header tw-text-center">
  <p class="tw-uppercase tw-tracking-wide tw-font-bold tw-text-center tw-text-sm tw-text-neutral-400">Z-Link Stats</p>
  <h1><%= @url.keyword %></h1>
</header>
<div class="tw-p-4">
  <div class="umn-post-it">
    <div class="row">
      <div class="col-md-7">
        <div class="row">
          <div class="col-md-6">
            <div class="panel panel-default">
              <h2 class="panel-heading tw-mb-0 tw-text-base tw-text-left"><%= t('views.urls.show.short_url') %></h2>
              <div class="panel-body">
                <a target='_blank' href="<%= full_url(@url) %>"><%= full_url(@url) %></a>
                <button class='btn btn-default clipboard-btn' data-clipboard-text="<%= full_url(@url) %>" data-cy="copy-button">
                  <i class=" fa fa-files-o"></i>
                  <%= t('views.urls.show.thing.copy') %>
                </button>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="panel panel-default">
              <h2 class="panel-heading tw-mb-0 tw-text-base tw-text-left"><%= t('views.urls.show.source_url') %></h2>
              <div class="panel-body">
                <a target='_blank' href="<%= @url.url %>"><%= @url.url %></a>
              </div>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-md-12 stats-actions">
            <div class="panel panel-default">
              <h2 class="panel-heading tw-mb-0 tw-text-base tw-text-left"><%= t('views.urls.show.collection') %></h2>
              <div class="panel-body">
                <% user_groups_for_collection = group_names_and_ids_for_select(current_user.groups)%>
                <%= select_tag(
              "url-collection-#{@url.id}",
              options_for_select(
                user_groups_for_collection,
                @url.group_id
              ),
              class: 'form-control selectpicker collection-picker ',
              data: {
                update_path: url_path(@url.id),
                keyword: @url.keyword,
                group_id: @url.group_id
              }
            ) %>
              </div>
            </div>
            <button class="btn btn-primary js-transfer-urls ">
              <i class="fa fa-exchange"></i>
              <%= t('views.urls.transfer_button') %>
            </button>
          </div>
        </div>
        <div class="traffic-stats-header">
          <h2 class="tw-mb-0"><%= t('views.urls.show.traffic_stats') %></h2>
          <a class='btn btn-default js-csv-download' href="<%= url_csv_click_data_path(@url, format: :csv) %>"><%= t('views.urls.show.export_button') %></a>
        </div>
        <div class="row">
          <div class="col-md-12">
            <div data-behavior="vue">
              <url-stats-page keyword="<%= @url.keyword %>"></url-stats-page>
            </div>
          </div>
        </div>
        <h2><%= t('views.urls.show.traffic_location')%></h2>
        <div class="row">
          <div id="regions-div" class="col-md-12" aria-hidden="true">
          </div>
        </div>
        <div class="row">
          <div id="regions-pie-div" class="col-md-12" aria-hidden="true">
          </div>
        </div>
        <!-- Accessible location data table for screen readers -->
        <div class="sr-only">
          <h4>Traffic by Location</h4>
          <table>
            <thead>
              <tr>
                <th scope="col">Country</th>
                <th scope="col">Clicks</th>
              </tr>
            </thead>
            <tbody>
              <% @clicks[:regions].each do |country_code, count| %>
                <tr>
                  <td><%= country_code.present? ? country_code : 'Unknown' %></td>
                  <td><%= count %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="col-md-5">
        <div class="row">
          <div class="col-md-12">
            <div class="panel panel-default">
              <h2 class="panel-heading tw-mb-0 tw-text-base tw-text-left">Note</h2>
              <div class="panel-body text-center">
                <%= form_with model: @url, url: note_url_path(@url.keyword), method: :patch, data: { cy: 'note-form' } do |form|%>
                  <%= form.label :note, "Note", class: 'sr-only' %>
                  <%= form.text_area :note, class: 'form-control', placeholder: 'Add a note', data: { cy: 'note-input' } %>
                  <div class="tw-mt-2 tw-flex tw-justify-end tw-gap-2 tw-items-center">
                    <%= button_tag 'Reset', type: 'reset', class: "tw-uppercase tw-text-xs tw-bg-neutral-100 tw-px-4 tw-py-2 tw-rounded hover:tw-bg-neutral-200 tw-transition" %>
                    <%= form.button "Save", class: "btn btn-primary" %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-md-12">
            <div class="panel panel-default">
              <h2 class="panel-heading tw-mb-0 tw-text-base tw-text-left"><%= t('views.urls.show.share') %></h2>
              <div class="panel-body text-center">
                <%= render "/urls/share_buttons", url: @url, large: true %>
              </div>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-md-12">
            <div class="panel panel-default">
              <h2 class="panel-heading tw-mb-0 tw-text-base tw-text-left"><%= t('views.urls.show.created_on')%></h2>
              <div class="panel-body">
                <%= @url.created_at.to_fs(:created_on_formatted) %> (<%= time_ago_in_words(@url.created_at) %> ago)
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%= render 'modal' %>
<script type="text/javascript">
  // Google Charts for geographic data (country map/pie) — time-series charts are now Vue
  <%= render partial: 'urls/show_js/country_map', formats: :js %>
  <%= render partial: 'urls/show_js/country_pie', formats: :js %>
  <%= render partial: 'urls/show_js/move', formats: :js %>
  <%= render partial: 'urls/show_js/transfer', formats: :js %>
</script>
